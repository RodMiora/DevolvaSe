# Cloudflare R2 Config
R2_ACCESS_KEY_ID=seu_access_key_id
R2_SECRET_ACCESS_KEY=seu_secret_access_key
R2_BUCKET_NAME=nome_do_seu_bucket
R2_ENDPOINT_URL=https://<id-da-conta>.r2.cloudflarestorage.com

# Supabase (opcional para o backend se for usar a lib do supabase)
SUPABASE_URL=sua_url_do_supabase
SUPABASE_KEY=sua_service_role_key
